# Server
PORT=3001
WEB_ORIGIN=http://localhost:5173

# Session / auth
# Used by the current API runtime.
SESSION_SECRET=replace-with-a-long-random-development-secret

# Reserved placeholders for future integrations.
# The current MVP code path always uses mock login and mock generation.
AUTH_MODE=mock
GENERATION_MODE=mock

# OpenAI-compatible image generation placeholders
# Not used by the current mock-only MVP.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=replace-with-your-openai-compatible-api-key
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_QUALITY=high

# Dayu / OIDC placeholders
# Real OIDC login is not implemented in this MVP yet.
OIDC_DISCOVERY_URL=https://friends.chenyu.cy/oidc/.well-known/openid-configuration
OIDC_CLIENT_ID=dayu-web-client
OIDC_CLIENT_SECRET=replace-with-your-oidc-client-secret
OIDC_REDIRECT_URI=http://localhost:3001/auth/callback
OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:5173/login
