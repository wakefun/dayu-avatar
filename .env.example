# The API auto-loads the repository root .env at startup.
# Existing system environment variables take precedence and are not overwritten.

# Server
PORT=3001
WEB_ORIGIN=http://localhost:5173

# Session / auth
SESSION_SECRET=replace-with-a-long-random-development-secret
AUTH_MODE=mock

# Generation provider
GENERATION_MODE=mock

# OpenAI-compatible image generation
# If OPENAI_BASE_URL already ends with /v1, the API calls /images/edits under it.
# Otherwise the runtime appends /v1/images/edits.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=replace-with-your-openai-compatible-api-key
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_QUALITY=high
OPENAI_REQUEST_TIMEOUT_MS=600000

# Dayu / OIDC login
OIDC_DISCOVERY_URL=https://friends.chenyu.cy/oidc/.well-known/openid-configuration
OIDC_CLIENT_ID=dayu-web-client
OIDC_CLIENT_SECRET=replace-with-your-oidc-client-secret
OIDC_REDIRECT_URI=http://localhost:3001/api/auth/callback
OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:5173/login
